--cpu Cortex-M0+
"5-relay\startup_stm32g070xx.o"
"5-relay\main.o"
"5-relay\stm32g0xx_it.o"
"5-relay\stm32g0xx_hal_msp.o"
"5-relay\stm32g0xx_hal_i2c.o"
"5-relay\stm32g0xx_hal_i2c_ex.o"
