"5-relay\stm32g0xx_hal_rcc_ex.o"
"5-relay\stm32g0xx_ll_rcc.o"
"5-relay\stm32g0xx_hal_flash.o"
"5-relay\stm32g0xx_hal_flash_ex.o"
"5-relay\stm32g0xx_hal_gpio.o"
"5-relay\stm32g0xx_hal_dma.o"
"5-relay\stm32g0xx_hal_dma_ex.o"
"5-relay\stm32g0xx_hal_pwr.o"
"5-relay\stm32g0xx_hal_pwr_ex.o"
"5-relay\stm32g0xx_hal_cortex.o"
