--cpu Cortex-M0+
"3-led\startup_stm32g070xx.o"
"3-led\main.o"
"3-led\stm32g0xx_it.o"
"3-led\stm32g0xx_hal_msp.o"
"3-led\stm32g0xx_hal_i2c.o"
"3-led\stm32g0xx_hal_i2c_ex.o"
"3-led\stm32g0xx_hal_rcc.o"
"3-led\stm32g0xx_hal_rcc_ex.o"
"3-led\stm32g0xx_ll_rcc.o"
"3-led\stm32g0xx_hal_flash.o"
"3-led\stm32g0xx_hal_flash_ex.o"
"3-led\stm32g0xx_hal_gpio.o"
"3-led\stm32g0xx_hal_dma.o"
"3-led\stm32g0xx_hal_dma_ex.o"
"3-led\stm32g0xx_hal_pwr.o"
"3-led\stm32g0xx_hal_pwr_ex.o"
"3-led\stm32g0xx_hal_cortex.o"
"3-led\stm32g0xx_hal.o"
"3-led\stm32g0xx_hal_exti.o"
"3-led\stm32g0xx_hal_uart.o"
"3-led\stm32g0xx_hal_uart_ex.o"
"3-led\system_stm32g0xx.o"
"3-led\myapp.o"
"3-led\stm32printfuart.o"
--library_type=microlib --strict --scatter "3-LED\3-LED.sct"
--summary_stderr --info summarysizes --map --load_addr_map_info --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list "3-LED.map" -o 3-LED\3-LED.axf